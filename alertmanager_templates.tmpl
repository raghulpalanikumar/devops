{{ define "email.default.subject" }}
[{{ .Status | toUpper }}] {{ .CommonLabels.alertname }}
{{- end }}

{{ define "email.default.html" }}
<html>
  <body>

    {{ if gt (len .Alerts.Firing) 0 }}
    <h2 style="color: #d32f2f;">🚨 ALERT FIRING</h2>
    {{ range .Alerts.Firing }}
    <div style="border: 1px solid #d32f2f; padding: 10px; margin: 10px 0; background-color: #ffebee;">
      <h3>{{ .Labels.alertname }}</h3>
      <p><strong>Instance:</strong> {{ .Labels.instance }}</p>
      <p><strong>Job:</strong> {{ .Labels.job }}</p>
      <p><strong>Summary:</strong> {{ .Annotations.summary }}</p>
      <p><strong>Description:</strong> {{ .Annotations.description }}</p>
      <p><strong>Started At:</strong> {{ .StartsAt }}</p>
    </div>
    {{ end }}
    {{ end }}

    {{ if gt (len .Alerts.Resolved) 0 }}
    <h2 style="color: #388e3c;">✅ ALERT RESOLVED</h2>
    {{ range .Alerts.Resolved }}
    <div style="border: 1px solid #388e3c; padding: 10px; margin: 10px 0; background-color: #e8f5e9;">
      <h3>{{ .Labels.alertname }}</h3>
      <p><strong>Resolved At:</strong> {{ .EndsAt }}</p>
    </div>
    {{ end }}
    {{ end }}

  </body>
</html>
{{- end }}